<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_approval_decision_wizard_form" model="ir.ui.view">
        <field name="name">nn.approval.decision.wizard.form</field>
        <field name="model">nn.approval.decision.wizard</field>
        <field name="arch" type="xml">
            <form string="Provide Decision Comments">
                <group>
                    <field name="comment" placeholder="Write your remarks here..."/>
                    <field name="res_model" invisible="1"/>
                    <field name="res_id" invisible="1"/>
                    <field name="action_type" invisible="1"/>
                </group>
                <footer>
                    <button string="Confirm Action" name="action_confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>