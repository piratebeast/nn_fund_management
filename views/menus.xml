<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions -->
    <record id="action_nn_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_nn_fund_transaction" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">nn.fund.account.transaction</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu Hierarchies -->
    <menuitem id="menu_nn_fund_root" name="Fund Management" web_icon="nn_fund_management,static/description/icon.png" sequence="10"/>
    
    <menuitem id="menu_nn_fund_configuration" name="Configuration" parent="menu_nn_fund_root" sequence="100"/>
    <menuitem id="menu_nn_fund_account" name="Fund Accounts" parent="menu_nn_fund_configuration" action="action_nn_fund_account" sequence="10"/>

    <menuitem id="menu_nn_fund_operations" name="Operations" parent="menu_nn_fund_root" sequence="20"/>
    <menuitem id="menu_nn_incoming_funds" name="Incoming Funds" parent="menu_nn_fund_operations" action="action_nn_fund_transaction" sequence="10"/>
</odoo>