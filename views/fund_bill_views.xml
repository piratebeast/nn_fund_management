<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_bill_form" model="ir.ui.view">
        <field name="name">nn.fund.bill.form</field>
        <field name="model">nn.fund.bill</field>
        <field name="arch" type="xml">
            <form string="Vendor Invoice Execution">
                <header>
                    <button name="action_post" string="Post Bill" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel Bill" type="object" class="btn-secondary" invisible="state != 'posted'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Source Reference Mapping">
                            <field name="requisition_id" 
                                   options="{'no_create': True, 'no_open': False}" 
                                   domain="[('state', '=', 'approved'), ('remaining_billable_amount', '>', 0)]" 
                                   readonly="state != 'draft'"/>
                            <field name="project_id" readonly="1"/>
                            <field name="expense_head_id" readonly="1"/>
                        </group>
                        <group string="Invoice Parameter Details">
                            <field name="supplier_id" context="{'res_partner_search_mode': 'supplier'}" readonly="state != 'draft'"/>
                            <field name="bill_date" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Internal Remarks">
                        <field name="description" placeholder="Internal breakdown details..." readonly="state != 'draft'"/>
                        <field name="company_id" groups="base.group_multi_company" readonly="state != 'draft'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_bill_tree" model="ir.ui.view">
        <field name="name">nn.fund.bill.list</field>
        <field name="model">nn.fund.bill</field>
        <field name="arch" type="xml">
            <list string="Vendor Bill Management Ledger" decoration-success="state == 'posted'" decoration-info="state == 'draft'">
                <field name="bill_date"/>
                <field name="name"/>
                <field name="requisition_id"/>
                <field name="supplier_id"/>
                <field name="amount" sum="Total Invoiced Outflows"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'" decoration-info="state == 'draft'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="action_nn_fund_bill" model="ir.actions.act_window">
        <field name="name">Vendor Bills</field>
        <field name="res_model">nn.fund.bill</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>