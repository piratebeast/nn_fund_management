<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_nn_fund_allocation" model="ir.sequence">
            <field name="name">Fund Allocation Sequence</field>
            <field name="code">nn.fund.allocation</field>
            <field name="prefix">ALC-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_nn_fund_requisition" model="ir.sequence">
            <field name="name">Fund Requisition Sequence</field>
            <field name="code">nn.fund.requisition</field>
            <field name="prefix">REQ-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_nn_fund_bill" model="ir.sequence">
            <field name="name">Vendor Bill Sequence</field>
            <field name="code">nn.fund.bill</field>
            <field name="prefix">BILL-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_nn_fund_transfer" model="ir.sequence">
            <field name="name">Account Transfer Sequence</field>
            <field name="code">nn.fund.transfer</field>
            <field name="prefix">XFR-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>