<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_allocation_form" model="ir.ui.view">
        <field name="name">nn.fund.allocation.form</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Fund Allocation Request">
                <header>
                    <button name="action_submit" string="Submit Request" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    
                    <button name="%(nn_fund_management.action_nn_approval_decision_wizard)d" 
                     string="GM Approve" 
                     type="action" 
                     class="oe_highlight" 
                     context="{'default_action_type': 'gm_approve', 'default_res_model': 'nn.fund.allocation', 'default_res_id': id}" 
                     groups="nn_fund_management.group_gm_approver" 
                     invisible="state != 'gm_approval'"/>

                    <button name="%(nn_fund_management.action_nn_approval_decision_wizard)d"
                     string="MD Approve" 
                     type="action" 
                     class="oe_highlight" 
                     context="{'default_action_type': 'md_approve', 'default_res_model': 'nn.fund.allocation', 'default_res_id': id}" 
                     groups="nn_fund_management.group_md_approver" 
                     invisible="state != 'md_approval'"/>
                    
                    <button name="%(nn_fund_management.action_nn_approval_decision_wizard)d"
                     string="Reject" 
                     type="action" 
                     class="btn-danger" 
                     context="{'default_action_type': 'reject', 'default_res_model': 'nn.fund.allocation', 'default_res_id': id}" 
                     groups="nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver" 
                     invisible="state not in ['gm_approval', 'md_approval']"/>

                    <button name="%(nn_fund_management.action_nn_approval_decision_wizard)d" 
                     string="Cancel Request" 
                     type="action" 
                     class="btn-secondary" 
                     context="{'default_action_type': 'cancel', 'default_res_model': 'nn.fund.allocation', 'default_res_id': id}" 
                     groups="nn_fund_management.group_fund_admin" 
                     invisible="state not in ['approved', 'submitted', 'gm_approval', 'md_approval']"/>
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,gm_approval,md_approval,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Source and Value">
                            <field name="fund_account_id" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                        </group>
                        <group string="Allocation Destination Target">
                            <field name="project_id" placeholder="Select project if applicable" readonly="state != 'draft'"/>
                            <field name="expense_head_id" placeholder="Select expense head if applicable" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Details">
                        <field name="purpose" readonly="state != 'draft'"/>
                        <field name="attachment" filename="filename" readonly="state != 'draft'"/>
                        <field name="requested_by"/>
                        <field name="request_date"/>
                    </group>
                    <notebook>
                        <page string="Approval Logs &amp; Audit Trail">
                            <field name="approval_history_ids" readonly="1">
                                <list>
                                    <field name="date"/>
                                    <field name="approver_id"/>
                                    <field name="approval_level"/>
                                    <field name="result"/>
                                    <field name="comment"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_allocation_tree" model="ir.ui.view">
        <field name="name">nn.fund.allocation.tree</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <list string="Allocations" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount" sum="Total Allocations"/>
                <field name="request_date"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'" decoration-warning="state in ['gm_approval', 'md_approval']" decoration-danger="state == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="action_nn_fund_allocation" model="ir.actions.act_window">
        <field name="name">Allocation Requests</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>