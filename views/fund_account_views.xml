<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form string="Fund Account">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Dutch-Bangla Bank A/C"/></h1>
                    </div>
                    <group>
                        <group string="Balances">
                            <field name="total_received" readonly="1"/>
                            <field name="unassigned_balance" readonly="1"/>
                            <field name="amount_held" readonly="1"/>
                            <field name="total_assigned" readonly="1"/>
                        </group>
                        <group string="Metadata">
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_account_tree" model="ir.ui.view">
        <field name="name">nn.fund.account.tree</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <list string="Fund Accounts">
                <field name="name"/>
                <field name="total_received"/>
                <field name="unassigned_balance"/>
                <field name="amount_held"/>
                <field name="total_assigned"/>
            </list>
        </field>
    </record>

    <record id="view_nn_fund_transaction_form" model="ir.ui.view">
        <field name="name">nn.fund.account.transaction.form</field>
        <field name="model">nn.fund.account.transaction</field>
        <field name="arch" type="xml">
            <form string="Incoming Fund">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="TXN12345678" readonly="state == 'confirmed'"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="fund_account_id" readonly="state == 'confirmed'"/>
                            <field name="amount" readonly="state == 'confirmed'"/>
                        </group>
                        <group>
                            <field name="date" readonly="state == 'confirmed'"/>
                            <field name="sender" placeholder="Client Name / Investor" readonly="state == 'confirmed'"/>
                            <field name="company_id" groups="base.group_multi_company" readonly="state == 'confirmed'"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Notes..." readonly="state == 'confirmed'"/>
                        <field name="attachment" filename="filename" readonly="state == 'confirmed'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nn_fund_transaction_tree" model="ir.ui.view">
        <field name="name">nn.fund.account.transaction.tree</field>
        <field name="model">nn.fund.account.transaction</field>
        <field name="arch" type="xml">
            <list string="Incoming Funds" decoration-success="state == 'confirmed'">
                <field name="date"/>
                <field name="name"/>
                <field name="fund_account_id"/>
                <field name="sender"/>
                <field name="amount" sum="Total Received"/>
                <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-info="state == 'draft'"/>
            </list>
        </field>
    </record>

    <record id="action_nn_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_nn_fund_transaction" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">nn.fund.account.transaction</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>